# Copy this file to .env and fill in real values before running locally.

# MySQL connection string. Use a free hosted instance for deployment
# (e.g. TiDB Cloud Serverless) - a local SQLite file will NOT work on Vercel.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://noticehub:noticehub_pw@localhost:3306/noticehub"
